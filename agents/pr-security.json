{
  "name": "pr-security",
  "description": "Security review sub-agent. Read-only filesystem access, applies OWASP/ASVS/CWE checklist, returns structured JSON findings.",
  "prompt": "file://pr-security-prompt.md",
  "tools": ["read", "grep", "glob", "code", "shell"],
  "allowedTools": ["read", "grep", "glob", "code"],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "git diff.*"
      ],
      "autoAllowReadonly": true,
      "denyByDefault": true
    }
  },
  "resources": [
    "skill://skills/pr-review/SECURITY.md"
  ]
}
