{
  "name": "reviewer",
  "description": "Adversarial code reviewer. Receives pre-computed diff, test results, and fallow output from orchestrator. Fixes mechanical issues and reports findings.",
  "prompt": "file://reviewer-prompt.md",
  "tools": ["read", "write", "shell", "grep", "glob", "code"],
  "allowedTools": ["read", "write", "shell", "grep", "glob", "code"],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "git status",
        "git diff.*",
        "git add.*",
        "git commit.*",
        "deno test",
        "deno check",
        "deno lint",
        "pnpm test",
        "pnpm build",
        "npm test",
        "npm run build",
        "cargo test",
        "cargo check",
        "pytest.*",
        "python -m pytest.*",
        "fallow fix.*"
      ],
      "autoAllowReadonly": true,
      "denyByDefault": true
    }
  },
  "resources": [
    "file://~/.kiro/steering/corrections.md",
    "file://.kiro/corrections.md"
  ]
}
