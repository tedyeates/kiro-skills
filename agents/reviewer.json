{
  "name": "reviewer",
  "description": "Independent code reviewer. Reviews diff, assesses test quality, finds issues, runs checks, and fixes problems.",
  "prompt": "file://reviewer-prompt.md",
  "tools": ["read", "write", "shell", "grep", "glob", "code"],
  "allowedTools": ["read", "write", "shell", "grep", "glob", "code"],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "gh issue view.*",
        "git status",
        "git diff.*",
        "git add.*",
        "git commit.*",
        "deno test",
        "deno check",
        "deno lint",
        "pnpm test.*",
        "pnpm build.*",
        "pnpm run.*",
        "pnpm lint.*",
        "npm test.*",
        "npm run.*",
        "tsc.*",
        "mypy.*",
        "cargo test.*",
        "cargo check.*",
        "cargo build.*",
        "pytest.*",
        "python -m pytest.*",
        ".venv/Scripts/pytest.*",
        ".venv/Scripts/mypy.*",
        ".venv/bin/pytest.*",
        ".venv/bin/mypy.*"
      ],
      "autoAllowReadonly": true,
      "denyByDefault": true
    }
  },
  "resources": [
    "file://~/.kiro/steering/corrections.md",
    "file://.kiro/corrections.md"
  ]
}
