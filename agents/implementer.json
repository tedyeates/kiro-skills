{
  "name": "implementer",
  "description": "Constrained agent for implementing individual tasks via TDD. Accepts a task number, fetches the GitHub issue, reads design.md for context, and implements.",
  "prompt": "file://implementer-prompt.md",
  "tools": ["read", "write", "shell", "grep", "glob", "code"],
  "allowedTools": ["read", "grep", "glob", "code"],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "gh issue view",
        "gh issue develop",
        "git checkout",
        "git add",
        "git commit",
        "deno test",
        "deno check",
        "deno lint",
        "deno fmt",
        "pnpm test",
        "pnpm build",
        "pnpm lint",
        "npm test",
        "npm run build",
        "cargo test",
        "cargo check",
        "cargo build",
        "git status",
        "git diff"
      ],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "skill://~/.kiro/skills/tdd/SKILL.md",
    "skill://~/.kiro/skills/diagnose/SKILL.md",
    "file://~/.kiro/steering/corrections.md",
    "file://.kiro/corrections.md"
  ]
}
