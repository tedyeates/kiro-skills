{
  "name": "implementer",
  "description": "Constrained agent for implementing individual tasks via TDD. Receives task context inline, reads design.md for context, and implements.",
  "prompt": "file://implementer-prompt.md",
  "tools": ["read", "write", "shell", "grep", "glob", "code"],
  "allowedTools": ["read", "write", "shell", "grep", "glob", "code"],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "git add.*",
        "git commit.*",
        "git status",
        "git diff.*",
        "deno test",
        "deno check",
        "deno lint",
        "deno fmt",
        "pnpm test.*",
        "pnpm build.*",
        "pnpm run.*",
        "pnpm lint.*",
        "pnpm install.*",
        "pnpm add.*",
        "npm test.*",
        "npm run.*",
        "npm install.*",
        "tsc.*",
        "mypy.*",
        "cargo test.*",
        "cargo check.*",
        "cargo build.*",
        "cargo add.*",
        "pytest.*",
        "python -m pytest.*",
        "pip install.*",
        ".venv/Scripts/pytest.*",
        ".venv/Scripts/mypy.*",
        ".venv/Scripts/pip install.*",
        ".venv/bin/pytest.*",
        ".venv/bin/mypy.*",
        ".venv/bin/pip install.*"
      ],
      "autoAllowReadonly": true,
      "denyByDefault": true
    }
  },
  "resources": [
    "skill://~/.kiro/skills/tdd/SKILL.md",
    "file://~/.kiro/steering/corrections.md",
    "file://.kiro/corrections.md"
  ]
}
